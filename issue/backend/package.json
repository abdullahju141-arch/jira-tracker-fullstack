{
  "name": "jira-tracker-backend",
  "version": "1.0.0",
  "description": "Production backend for Jira-like Collaborative Issue Tracker — Next.js + Redux Toolkit frontend",
  "main": "dist/server.js",
  "scripts": {
    "dev":        "ts-node-dev --respawn --transpile-only src/server.ts",
    "build":      "tsc",
    "start":      "node dist/server.js",
    "seed":       "ts-node src/scripts/seed.ts",
    "seed:small": "ts-node src/scripts/seed_small.ts",
    "lint":       "eslint src --ext .ts"
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "mongoose":          "^8.3.4",
    "morgan":            "^1.10.0",
    "ws":                "^8.17.0",
    "express-rate-limit":"^7.2.0",
    "uuid":              "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs":   "^2.4.6",
    "@types/cors":       "^2.8.17",
    "@types/express":    "^4.17.21",
    "@types/jsonwebtoken":"^9.0.6",
    "@types/morgan":     "^1.9.9",
    "@types/node":       "^20.12.7",
    "@types/ws":         "^8.5.10",
    "@types/uuid":       "^9.0.8",
    "ts-node-dev":       "^2.0.0",
    "typescript":        "^5.4.5"
  },
  "engines": { "node": ">=18.0.0" }
}
